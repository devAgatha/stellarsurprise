{
  "name": "stellarsurprise",
  "version": "1.0.0",
  "private": true,
  "description": "Time-locked cash gifts on the Stellar blockchain",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "jest --forceExit",
    "test:watch": "jest --watch",
    "contract:build": "cd contracts/escrow && cargo build --target wasm32-unknown-unknown --release",
    "contract:test": "cd contracts/escrow && cargo test",
    "contract:deploy": "ts-node scripts/deploy-contract.ts",
    "db:migrate": "ts-node scripts/migrate.ts"
  },
  "dependencies": {
    "@stellar/stellar-sdk": "12.0.0",
    "@stellar/freighter-api": "2.0.0",
    "@supabase/supabase-js": "2.43.4",
    "axios": "1.6.8",
    "bcryptjs": "2.4.3",
    "date-fns": "3.6.0",
    "ioredis": "5.3.2",
    "jsonwebtoken": "9.0.2",
    "next": "14.2.3",
    "next-auth": "4.24.7",
    "pg": "8.11.3",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "uuid": "9.0.1",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "2.4.6",
    "@types/jest": "29.5.12",
    "@types/jsonwebtoken": "9.0.6",
    "@types/node": "20.12.7",
    "@types/pg": "8.11.5",
    "@types/react": "18.3.1",
    "@types/react-dom": "18.3.0",
    "@types/uuid": "9.0.8",
    "eslint": "8.57.0",
    "eslint-config-next": "14.2.3",
    "jest": "29.7.0",
    "ts-jest": "29.1.2",
    "ts-node": "10.9.2",
    "typescript": "5.4.5"
  }
}
